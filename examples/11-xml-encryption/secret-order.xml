<?xml version="1.0" encoding="UTF-8"?>
<!-- A purchase order. Some fields are sensitive (PAN, CVV, email); most are not.
     Element-level encryption lets us protect ONLY the sensitive fields while the
     rest of the document stays readable and routable by middleware. -->
<order id="SO-2026-0042">
  <customer>
    <name>Ada Lovelace</name>
    <email>ada@example.com</email>
  </customer>
  <payment>
    <method>card</method>
    <pan>4111111111111111</pan>
    <cvv>123</cvv>
    <expiry>2029-04</expiry>
  </payment>
  <lines>
    <line sku="XSLT-101" qty="1">Learning XSLT</line>
    <line sku="SEC-201" qty="2">Serious Cryptography</line>
  </lines>
  <total currency="USD">149.85</total>
</order>
